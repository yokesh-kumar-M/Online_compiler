# =============================================================================
# ENVIRONMENT CONFIGURATION - Online Compiler Enterprise
# =============================================================================
# Copy this file to .env and fill in your values

# Django Settings
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# PostgreSQL Database
POSTGRES_DB=online_compiler
POSTGRES_USER=compiler_admin
POSTGRES_PASSWORD=change-me-secure-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://compiler_admin:change-me-secure-password@postgres:5432/online_compiler

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# OAuth 2.0 / JWT
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost/api/v1/auth/github/callback

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/google/callback

# Executor Microservice
EXECUTOR_SERVICE_URL=http://executor:8001
EXECUTOR_API_KEY=change-me-executor-api-key
CODE_EXECUTION_TIMEOUT=10
MAX_OUTPUT_SIZE=10000

# Rate Limiting
RATE_LIMIT_ANONYMOUS=20/hour
RATE_LIMIT_AUTHENTICATED=100/hour
RATE_LIMIT_PREMIUM=1000/hour

# Email (for password reset etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# Monitoring
SENTRY_DSN=
LOG_LEVEL=INFO

# CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000
